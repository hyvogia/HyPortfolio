<!--================ Start Banner Area =================-->
<section class="banner_area">
    <div class="banner_inner d-flex align-items-center">
        <div class="container">
            <div class="banner_content text-center">
                <h2>Experiences</h2>
                <div class="page_link">
                    <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    <a asp-area="" asp-controller="Services" asp-action="Index">Experience</a>
                </div>
            </div>
        </div>
    </div>
</section>
<!--================ End Banner Area =================-->
<!--================ Start Features Area =================-->
<section id="feature_area" class="features_area section_top_half">
    <div class="container">
        <div class="row feature_inner">
            <div class="col-lg-3 col-md-6">
                <div class="feature_item">
                    <img src="img/services/s2.png" alt="">
                    <h4>Data Analysis</h4>
                    <p>Python with Pandas library and Power BI for data visualization</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="feature_item">
                    <img src="img/services/s1.png" alt="">
                    <h4>Web App Development</h4>
                    <p>C# .NET Core MVC with Boostrap and React</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="feature_item">
                    <img src="img/services/s3.png" alt="">
                    <h4>API & Microservices</h4>
                    <p>Java Spring Boot with React</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="feature_item">
                    <img src="img/services/s4.png" alt="">
                    <h4>IoT</h4>
                    <p>Apple Technician Certification</p>
                </div>
            </div>
        </div>
    </div>
</section>
<!--================ End Features Area =================-->
